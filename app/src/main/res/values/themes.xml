<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ════════════════════════════════════════════════════════════════════
         Base application theme (Light Mode)
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Theme.FeiertageDE" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand colour -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>
        <!-- Tertiary -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>
        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <!-- Outline -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>
        <!-- Status / nav bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface_container_lowest</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Shape tokens -->
        <item name="shapeAppearanceSmallComponent">@style/Shape.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.Large</item>
        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Splash Screen theme
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Theme.FeiertageDE.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.FeiertageDE</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         BottomSheet style
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Theme.FeiertageDE.BottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheet.Style</item>
    </style>

    <style name="BottomSheet.Style" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/Shape.BottomSheet</item>
        <item name="backgroundTint">@color/surface_container_lowest</item>
    </style>

    <style name="Shape.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Shape tokens
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Shape.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>

    <style name="Shape.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="Shape.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Typography
    ════════════════════════════════════════════════════════════════════ -->
    <style name="TextAppearance.FeiertageDE" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.FeiertageDE.DisplayLg">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:lineHeight">40dp</item>
    </style>

    <style name="TextAppearance.FeiertageDE.HeadlineMd">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">24sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.FeiertageDE.TitleLg">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.FeiertageDE.BodyLg">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.FeiertageDE.BodyMd">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.FeiertageDE.LabelMd">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Card style
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Widget.FeiertageDE.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_container_lowest</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.FeiertageDE.Card.Holiday" parent="Widget.FeiertageDE.Card">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">1dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Button styles
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Widget.FeiertageDE.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.FeiertageDE.Button.Ghost" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/on_surface</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════════════
         Bottom Navigation
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Widget.FeiertageDE.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_icon_selector</item>
        <item name="itemTextColor">@color/bottom_nav_text_selector</item>
        <item name="android:background">@color/surface_container_lowest</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

</resources>
