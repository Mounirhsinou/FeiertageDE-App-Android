<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_calendar.xml – Monthly calendar grid view -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/calendar_title"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurface" />

    </LinearLayout>

    <!-- Month navigation row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_prev_month"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_chevron_left"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            style="@style/Widget.Material3.Button.IconButton" />

        <TextView
            android:id="@+id/tv_month_year"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Januar 2026"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_month"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            style="@style/Widget.Material3.Button.IconButton" />

    </LinearLayout>

    <!-- Day-of-week headers: Mo Di Mi Do Fr Sa So -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <TextView android:id="@+id/tv_cal_mon" style="@style/CalDayHeader" android:text="Mo" />
        <TextView android:id="@+id/tv_cal_tue" style="@style/CalDayHeader" android:text="Di" />
        <TextView android:id="@+id/tv_cal_wed" style="@style/CalDayHeader" android:text="Mi" />
        <TextView android:id="@+id/tv_cal_thu" style="@style/CalDayHeader" android:text="Do" />
        <TextView android:id="@+id/tv_cal_fri" style="@style/CalDayHeader" android:text="Fr" />
        <TextView android:id="@+id/tv_cal_sat" style="@style/CalDayHeader" android:text="Sa" android:textColor="?attr/colorOutline" />
        <TextView android:id="@+id/tv_cal_sun" style="@style/CalDayHeader" android:text="So" android:textColor="?attr/colorOutline" />

    </LinearLayout>

    <!-- Day grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false" />

    <!-- Legend -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_national"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="National"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginEnd="16dp" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_regional"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Landesfeiertag"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

</LinearLayout>
