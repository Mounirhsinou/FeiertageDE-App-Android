<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml – Main home screen layout.
    Structure:
    ┌─ NestedScrollView ──────────────────────────────────┐
    │  ┌─ Toolbar (logo + year chips + state chip) ──────┐│
    │  ├─ Search bar ────────────────────────────────────┤│
    │  ├─ "Next Holiday" hero card ──────────────────────┤│
    │  ├─ "Upcoming Holidays" header + RecyclerView ─────┤│
    │  ├─ Long Weekend + Regional cards ─────────────────┤│
    └──┴─────────────────────────────────────────────────┘
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ── Top bar ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🇩🇪  Feiertage DE"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurface" />

                <!-- State filter chip -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_state_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alle Länder"
                    app:chipIcon="@drawable/ic_location"
                    app:chipIconTint="?attr/colorPrimary"
                    app:chipBackgroundColor="?attr/colorSurfaceVariant"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- ── Year chips ────────────────────────────────────────── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true" />

            </HorizontalScrollView>

            <!-- ── Search bar ────────────────────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="?attr/colorOnSurfaceVariant"
                app:boxBackgroundColor="?attr/colorSurfaceVariant"
                app:boxStrokeColor="?attr/colorOutlineVariant">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── "Next Holiday" hero card ──────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_next_holiday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary"
                android:foreground="?attr/selectableItemBackground">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- "Nächster Feiertag" pill -->
                    <TextView
                        android:id="@+id/tv_next_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/next_holiday_label"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_next_pill"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- State label (top-right) -->
                    <TextView
                        android:id="@+id/tv_state_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alle Länder"
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Holiday name – big display font -->
                    <TextView
                        android:id="@+id/tv_next_holiday_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Tag der Deutschen Einheit"
                        android:textColor="@color/on_primary"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black"
                        android:lineHeight="34dp"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_next_label"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Countdown row -->
                    <LinearLayout
                        android:id="@+id/row_countdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_next_holiday_name"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_calendar_small"
                            app:tint="#AAFFFFFF" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="COUNTDOWN"
                                android:textColor="#99FFFFFF"
                                android:textSize="10sp"
                                android:letterSpacing="0.08"
                                android:textAllCaps="true"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tv_next_countdown"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3 Tage verbleibend"
                                android:textColor="@color/on_primary"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                        <!-- Weekday (right aligned) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tv_next_holiday_weekday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Samstag"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp"
                                android:gravity="end" />

                            <TextView
                                android:id="@+id/tv_next_holiday_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3. Oktober 2026"
                                android:textColor="@color/on_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="end" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Upcoming + Bridge Day cards row ─────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:weightSum="2">

                <!-- Bridge Day card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFF9EFD8">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="☀️"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bridge_days_label"
                            android:textColor="@color/tertiary"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:textAllCaps="true"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tv_bridge_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Optimal"
                            android:textColor="@color/on_surface"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tv_bridge_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2026 Strategie"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Regional States card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗺️"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/regional_label"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:textAllCaps="true"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="16 Länder"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Individuelle Liste"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── "Upcoming Holidays" section header ────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/upcoming_holidays"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- Empty state text -->
            <TextView
                android:id="@+id/tv_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_holidays"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <!-- ── Holiday list RecyclerView ─────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_holidays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
