<?xml version="1.0" encoding="utf-8"?>
<!-- item_state.xml – Single row in the state list -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_state"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="6dp"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="@drawable/bg_state_normal"
    android:foreground="?attr/selectableItemBackground">

    <!-- State code pill -->
    <TextView
        android:id="@+id/tv_state_code"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="BY"
        android:textSize="12sp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:textColor="?attr/colorOnSurface"
        android:background="@drawable/bg_state_code" />

    <!-- Name + capital -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tv_state_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bayern"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tv_state_capital"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="München"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Selected check mark -->
    <ImageView
        android:id="@+id/iv_state_check"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_check"
        app:tint="?attr/colorPrimary"
        android:visibility="gone" />

</LinearLayout>
